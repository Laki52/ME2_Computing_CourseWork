   "source": [
    "# In this section I am importing all the libraries I will need\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as pl"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "# In this section I am defining variables (arrays) that I would need to implement the method\n",
    "\n",
    "# physical parameters\n",
    "L = 0.05              # blade length, m\n",
    "k = 25.0              # thermal conductivity, W/m/K\n",
    "A = 2.0e-4            # cross-sectional area, m^2\n",
    "P = 0.08              # wetted perimeter, m\n",
    "hconv = 350.0         # convection coefficient, W/m^2/K\n",
    "Tinf = 1400.0         # surrounding gas temperature, K\n",
    "Tb = 900.0            # blade root temperature, K\n",
    "TL = 1050.0           # blade tip temperature, K\n",
    "\n",
    "# fin parameter\n",
    "m = np.sqrt(hconv * P / (k * A))\n",
    "\n",
    "# number of subintervals\n",
    "N = 40\n",
    "\n",
    "# Analytical solution for validation\n",
    "\n",
    "def T_analytical(x, L, m, Tinf, Tb, TL):\n",
    "    thetab = Tb - Tinf\n",
    "    thetaL = TL - Tinf\n",
    "    return Tinf + thetab*np.cosh(m*x) + (thetaL - thetab*np.cosh(m*L))*np.sinh(m*x)/np.sinh(m*L)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# In this section I am setting the boundary conditions/initial values\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "m = 74.83314773547883\n",
      "h = 0.00125\n",
      "maximum absolute error = 0.08552344771737808\n",
